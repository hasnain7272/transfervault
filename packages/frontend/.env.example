# TransferVault Frontend — Environment Variables
# Copy to .env and fill in your values.

# Supabase (from dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Daemon URL (where Cloudflare Tunnel or reverse proxy points to your laptop)
# In dev: http://localhost:3001
# In prod: https://vault-api.yourdomain.com (via Cloudflare Tunnel)
VITE_DAEMON_URL=http://localhost:3001
